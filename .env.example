# Copy this file to `.env` (gitignored) and fill in the values.
# NEVER commit `.env` — it leaks your keys.

# ─── Marketstack ─────────────────────────────────────────────────────────────
# Used by marketCheck.js to verify news-driven ticker moves.
# Sign up: https://marketstack.com/
MARKETSTACK_API_KEY=

# ─── X (Twitter) API v2 ──────────────────────────────────────────────────────
# Used sparingly by xCheck.js (once-per-hunt top-trends pull, with daily budget).
# Credentials at https://developer.x.com/
# NEVER put real values in THIS file — only in .env.
#
# OAuth 2.0 PKCE (user context — posting, following list reads):
X_CLIENT_ID=
X_CLIENT_SECRET=
#
# OAuth 1.0a / bearer-token (read-only endpoints, trends, recent search):
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Hard daily cap — xCheck.js will refuse calls past this limit.
# X Basic tier gives ~15K reads/month; keep low to leave headroom.
X_DAILY_CALL_BUDGET=50

# ─── Semantic Scholar (optional) ─────────────────────────────────────────────
# Unauthenticated works for low volume; set a key to raise rate limits.
# Request one: https://www.semanticscholar.org/product/api#api-key-form
SEMANTIC_SCHOLAR_API_KEY=

# ─── Gemini API (Google AI Studio) ───────────────────────────────────────────
# Used by presentations/tts.js to narrate news items with Gemini 2.5 Flash TTS.
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
